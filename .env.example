# FIRECRAWL_API_KEY is used by the local capture script (scripts/capture-loom-evidence.js).
# Get one at https://www.firecrawl.dev (free tier available). Copy this file to .env and fill it in.
FIRECRAWL_API_KEY=

# NOTE: the Potter MCP is configured SEPARATELY (not from this file). Potter needs its own keys,
# typically an Apify token (LinkedIn data) and a Firecrawl key (web). See USER-GUIDE.pdf.
